APP_NAME="ZIP Intelligence Platform API"
APP_VERSION="0.1.0"
DEFAULT_API_KEY=dev_demo
DEFAULT_TENANT_ID=demo
DEFAULT_PLAN=pro
BASIC_API_KEY=dev_basic
BASIC_TENANT_ID=demo-basic
TRIAL_API_KEY=dev_trial
TRIAL_TENANT_ID=demo-trial
ADMIN_API_KEY=dev_admin
ADMIN_TENANT_ID=platform
ENFORCE_QUOTAS=true
AUTO_PROCESS_EXPORTS=false

# Provider mode: inmemory (default) or postgres
STORAGE_MODE=inmemory

# Postgres
DATABASE_URL=postgresql+psycopg://monetize:monetize@localhost:5432/monetize

# Redis usage metering (optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# MinIO export artifacts (optional)
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=exports

# Telegram notifications (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=8965276121:AAEJNzqX4TEhYZBEZHzrR_ytJ-DXcqD
TELEGRAM_CHAT_ID=105722
